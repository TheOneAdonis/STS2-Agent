<Window x:Class="STS2AIAgent.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="创造性AI"
        Width="1140"
        Height="800"
        MinWidth="980"
        MinHeight="700"
        FontFamily="Microsoft YaHei UI"
        FontSize="12.5"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        Background="Transparent"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">
  <Window.Resources>
    <SolidColorBrush x:Key="WindowBrush" Color="#FFF5F6F7" />
    <SolidColorBrush x:Key="CardBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="PanelBrush" Color="#FFF9FAFB" />
    <SolidColorBrush x:Key="InputBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="BorderBrushSoft" Color="#FFDCE2E8" />
    <SolidColorBrush x:Key="TitleBrush" Color="#FF111827" />
    <SolidColorBrush x:Key="TextBrush" Color="#FF374151" />
    <SolidColorBrush x:Key="MutedBrush" Color="#FF6B7280" />
    <SolidColorBrush x:Key="AccentBrush" Color="#FF1F2937" />

    <Style x:Key="CardStyle" TargetType="Border">
      <Setter Property="Background" Value="{StaticResource CardBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="16" />
      <Setter Property="Padding" Value="16" />
    </Style>

    <Style x:Key="PanelStyle" TargetType="Border">
      <Setter Property="Background" Value="{StaticResource PanelBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="Padding" Value="12" />
    </Style>

    <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource TitleBrush}" />
      <Setter Property="FontSize" Value="16" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="BodyTextStyle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
      <Setter Property="FontSize" Value="12.5" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="CaptionTextStyle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
      <Setter Property="FontSize" Value="10.5" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
      <Setter Property="FontSize" Value="10.5" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Margin" Value="0,0,0,5" />
    </Style>

    <Style x:Key="CheckBoxStyle" TargetType="CheckBox">
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="FocusVisualStyle" Value="{x:Null}" />
    </Style>

    <Style x:Key="InputContainerStyle" TargetType="Border">
      <Setter Property="Background" Value="{StaticResource InputBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="11" />
      <Setter Property="Padding" Value="10,8" />
    </Style>

    <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
      <Setter Property="FontSize" Value="12.5" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="FocusVisualStyle" Value="{x:Null}" />
      <Setter Property="CaretBrush" Value="{StaticResource TitleBrush}" />
    </Style>

    <Style x:Key="InputPasswordStyle" TargetType="PasswordBox">
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
      <Setter Property="FontSize" Value="12.5" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="FocusVisualStyle" Value="{x:Null}" />
      <Setter Property="CaretBrush" Value="{StaticResource TitleBrush}" />
    </Style>

    <Style x:Key="PromptTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource InputTextBoxStyle}">
      <Setter Property="AcceptsReturn" Value="True" />
      <Setter Property="TextWrapping" Value="Wrap" />
      <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
      <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
      <Setter Property="VerticalContentAlignment" Value="Top" />
      <Setter Property="Height" Value="188" />
    </Style>

    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
      <Setter Property="Foreground" Value="White" />
      <Setter Property="Background" Value="{StaticResource AccentBrush}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Height" Value="34" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="FocusVisualStyle" Value="{x:Null}" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border CornerRadius="10"
                    BorderThickness="1"
                    BorderBrush="{TemplateBinding Background}"
                    Background="{TemplateBinding Background}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Opacity" Value="0.94" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter Property="Opacity" Value="0.84" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.42" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
      <Setter Property="Foreground" Value="{StaticResource TitleBrush}" />
      <Setter Property="Background" Value="{StaticResource CardBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border CornerRadius="10"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    Background="{TemplateBinding Background}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Opacity" Value="0.96" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter Property="Opacity" Value="0.88" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.42" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Grid Background="Transparent">
    <Border Background="{StaticResource WindowBrush}"
            BorderBrush="#18000000"
            BorderThickness="1"
            CornerRadius="22">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="60" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource CardBrush}"
                CornerRadius="22,22,0,0"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
          <Grid Margin="18,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel VerticalAlignment="Center">
              <TextBlock Text="创造性AI"
                         FontSize="18"
                         FontWeight="SemiBold"
                         Foreground="{StaticResource TitleBrush}" />
              <TextBlock x:Name="StatusHintTextBlock"
                         Style="{StaticResource CaptionTextStyle}"
                         Margin="0,2,0,0"
                         Text="等待连接游戏内服务。" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
              <Border Style="{StaticResource PanelStyle}"
                      Padding="10,5"
                      Margin="0,0,8,0">
                <TextBlock x:Name="VersionTextBlock"
                           Style="{StaticResource CaptionTextStyle}"
                           Text="v0.15.1" />
              </Border>
              <Button Width="32"
                      Height="26"
                      Margin="0,0,8,0"
                      Style="{StaticResource SecondaryButtonStyle}"
                      Click="MinimizeButton_Click"
                      Content="_" />
              <Button Width="32"
                      Height="26"
                      Style="{StaticResource SecondaryButtonStyle}"
                      Click="CloseButton_Click"
                      Content="X" />
            </StackPanel>
          </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="16">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="276" />
            <ColumnDefinition Width="14" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <Border Grid.Column="0"
                  Grid.RowSpan="3"
                  Style="{StaticResource CardStyle}">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          BorderThickness="0">
              <StackPanel>
                <TextBlock Text="设置" Style="{StaticResource SectionTitleStyle}" />

                <TextBlock Text="API Base URL"
                           Style="{StaticResource FieldLabelStyle}"
                           Margin="0,14,0,5" />
                <Border Style="{StaticResource InputContainerStyle}">
                  <TextBox x:Name="BaseUrlTextBox"
                           Style="{StaticResource InputTextBoxStyle}"
                           TextChanged="BaseConfigChanged" />
                </Border>

                <TextBlock Text="模型"
                           Style="{StaticResource FieldLabelStyle}"
                           Margin="0,12,0,5" />
                <Border Style="{StaticResource InputContainerStyle}">
                  <TextBox x:Name="ModelTextBox"
                           Style="{StaticResource InputTextBoxStyle}"
                           TextChanged="BaseConfigChanged" />
                </Border>

                <TextBlock Text="API Key"
                           Style="{StaticResource FieldLabelStyle}"
                           Margin="0,12,0,5" />
                <Border Style="{StaticResource InputContainerStyle}">
                  <PasswordBox x:Name="ApiKeyBox"
                               Style="{StaticResource InputPasswordStyle}"
                               PasswordChanged="ApiKeyBox_PasswordChanged" />
                </Border>

                <TextBlock Text="调试"
                           Style="{StaticResource FieldLabelStyle}"
                           Margin="0,12,0,5" />
                <Border Style="{StaticResource InputContainerStyle}">
                  <StackPanel>
                    <CheckBox x:Name="DebugModeCheckBox"
                              Style="{StaticResource CheckBoxStyle}"
                              Content="记录 LLM 调试日志"
                              Checked="DebugModeCheckBox_Changed"
                              Unchecked="DebugModeCheckBox_Changed" />
                    <TextBlock Style="{StaticResource CaptionTextStyle}"
                               Margin="24,4,0,0"
                               Text="写入 llm-debug.jsonl" />
                  </StackPanel>
                </Border>

                <TextBlock Text="操作"
                           Style="{StaticResource FieldLabelStyle}"
                           Margin="0,16,0,6" />
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <Button x:Name="SaveButton"
                          Grid.Column="0"
                          Style="{StaticResource SecondaryButtonStyle}"
                          Click="SaveButton_Click"
                          Content="保存" />
                  <Button x:Name="TestConnectionButton"
                          Grid.Column="2"
                          Style="{StaticResource SecondaryButtonStyle}"
                          Click="TestConnectionButton_Click"
                          Content="检测" />
                </Grid>

                <Grid Margin="0,8,0,0">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <Button x:Name="StartButton"
                          Grid.Column="0"
                          Style="{StaticResource PrimaryButtonStyle}"
                          Click="StartButton_Click"
                          Content="开始托管" />
                  <Button x:Name="StopButton"
                          Grid.Column="2"
                          Style="{StaticResource SecondaryButtonStyle}"
                          Click="StopButton_Click"
                          Content="停止" />
                </Grid>
              </StackPanel>
            </ScrollViewer>
          </Border>

          <Border Grid.Column="2"
                  Grid.Row="0"
                  Style="{StaticResource CardStyle}">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
              </Grid.RowDefinitions>

              <TextBlock Text="运行概览" Style="{StaticResource SectionTitleStyle}" />

              <Grid Grid.Row="1" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="0.9*" />
                  <ColumnDefinition Width="10" />
                  <ColumnDefinition Width="0.9*" />
                  <ColumnDefinition Width="10" />
                  <ColumnDefinition Width="1.15*" />
                  <ColumnDefinition Width="10" />
                  <ColumnDefinition Width="1.15*" />
                </Grid.ColumnDefinitions>

                <Border x:Name="GameStatusBadge"
                        Grid.Column="0"
                        Style="{StaticResource PanelStyle}">
                  <StackPanel>
                    <TextBlock Text="连接" Style="{StaticResource CaptionTextStyle}" />
                    <TextBlock x:Name="GameStatusTextBlock"
                               Margin="0,4,0,0"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TitleBrush}"
                               Text="未连接" />
                  </StackPanel>
                </Border>

                <Border x:Name="AgentStatusBadge"
                        Grid.Column="2"
                        Style="{StaticResource PanelStyle}">
                  <StackPanel>
                    <TextBlock Text="状态" Style="{StaticResource CaptionTextStyle}" />
                    <TextBlock x:Name="AgentStatusTextBlock"
                               Margin="0,4,0,0"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TitleBrush}"
                               Text="未启动" />
                  </StackPanel>
                </Border>

                <Border Grid.Column="4" Style="{StaticResource PanelStyle}">
                  <StackPanel>
                    <TextBlock Text="角色" Style="{StaticResource CaptionTextStyle}" />
                    <TextBlock x:Name="CharacterNameTextBlock"
                               Margin="0,4,0,0"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TitleBrush}"
                               Text="等待进入对局" />
                    <TextBlock x:Name="CharacterIdTextBlock"
                               Style="{StaticResource CaptionTextStyle}"
                               Margin="0,4,0,0"
                               Text="未进入对局" />
                  </StackPanel>
                </Border>

                <Border Grid.Column="6" Style="{StaticResource PanelStyle}">
                  <StackPanel>
                    <TextBlock Text="界面" Style="{StaticResource CaptionTextStyle}" />
                    <TextBlock x:Name="ScreenPhaseTextBlock"
                               Style="{StaticResource BodyTextStyle}"
                               Margin="0,4,0,0"
                               Text="主菜单 / 菜单阶段" />
                    <TextBlock x:Name="EditHintTextBlock"
                               Style="{StaticResource CaptionTextStyle}"
                               Margin="0,4,0,0"
                               Text="进入角色后可编辑提示词" />
                  </StackPanel>
                </Border>
              </Grid>

              <Border x:Name="InlineNoticeBorder"
                      Grid.Row="2"
                      Background="#18FFD39A"
                      BorderBrush="#44FFD39A"
                      BorderThickness="1"
                      CornerRadius="12"
                      Padding="12,9"
                      Margin="0,10,0,0"
                      Visibility="Collapsed">
                <TextBlock x:Name="InlineNoticeTextBlock"
                           Style="{StaticResource BodyTextStyle}"
                           Foreground="{StaticResource TitleBrush}"
                           Text="请进入游戏再启动 AI。" />
              </Border>

              <Grid Grid.Row="3" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="0.92*" />
                  <ColumnDefinition Width="12" />
                  <ColumnDefinition Width="1.08*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource PanelStyle}">
                  <StackPanel>
                    <TextBlock x:Name="ActiveAgentTitleTextBlock"
                               Style="{StaticResource SectionTitleStyle}"
                               Text="等待中" />
                    <TextBlock x:Name="EntryGuardTextBlock"
                               Style="{StaticResource CaptionTextStyle}"
                               Margin="0,6,0,0"
                               Text="进入对局后可启动。" />

                    <Border Height="1"
                            Margin="0,12,0,12"
                            Background="{StaticResource BorderBrushSoft}" />

                    <TextBlock Text="当前动作" Style="{StaticResource FieldLabelStyle}" />
                    <TextBlock x:Name="AgentActionTextBlock"
                               Style="{StaticResource BodyTextStyle}"
                               Text="正在观察" />
                  </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource PanelStyle}">
                  <StackPanel>
                    <TextBlock Text="计划" Style="{StaticResource FieldLabelStyle}" />
                    <TextBlock x:Name="AgentPlanTextBlock"
                               Style="{StaticResource BodyTextStyle}"
                               Text="暂无计划" />

                    <Border Height="1"
                            Margin="0,12,0,12"
                            Background="{StaticResource BorderBrushSoft}" />

                    <TextBlock Text="理由" Style="{StaticResource FieldLabelStyle}" />
                    <TextBlock x:Name="AgentReasonTextBlock"
                               Style="{StaticResource BodyTextStyle}"
                               Text="暂无推理" />

                    <Border Height="1"
                            Margin="0,12,0,12"
                            Background="{StaticResource BorderBrushSoft}" />

                    <TextBlock Text="错误" Style="{StaticResource FieldLabelStyle}" />
                    <TextBlock x:Name="AgentErrorTextBlock"
                               Style="{StaticResource BodyTextStyle}"
                               Text="当前没有错误。" />
                  </StackPanel>
                </Border>
              </Grid>
            </Grid>
          </Border>

          <Border Grid.Column="2"
                  Grid.Row="2"
                  Style="{StaticResource CardStyle}">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" />
              </Grid.RowDefinitions>

              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="16" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="提示词" Style="{StaticResource SectionTitleStyle}" />
                <TextBlock x:Name="PromptOwnerTextBlock"
                           Grid.Column="2"
                           Style="{StaticResource CaptionTextStyle}"
                           VerticalAlignment="Center"
                           Text="未检测到当前角色提示词。" />
              </Grid>

              <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="14" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="*" />
                  </Grid.RowDefinitions>

                  <TextBlock Text="战斗" Style="{StaticResource FieldLabelStyle}" />
                  <Border Grid.Row="2"
                          Style="{StaticResource InputContainerStyle}"
                          MouseLeftButtonDown="CombatPromptContainer_MouseLeftButtonDown">
                    <TextBox x:Name="CombatPromptTextBox"
                             Style="{StaticResource PromptTextBoxStyle}"
                             PreviewMouseLeftButtonDown="PromptTextBox_PreviewMouseLeftButtonDown"
                             TextChanged="CombatPromptTextBox_TextChanged" />
                  </Border>
                </Grid>

                <Grid Grid.Column="2">
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="*" />
                  </Grid.RowDefinitions>

                  <TextBlock Text="路线" Style="{StaticResource FieldLabelStyle}" />
                  <Border Grid.Row="2"
                          Style="{StaticResource InputContainerStyle}"
                          MouseLeftButtonDown="RoutePromptContainer_MouseLeftButtonDown">
                    <TextBox x:Name="RoutePromptTextBox"
                             Style="{StaticResource PromptTextBoxStyle}"
                             PreviewMouseLeftButtonDown="PromptTextBox_PreviewMouseLeftButtonDown"
                             TextChanged="RoutePromptTextBox_TextChanged" />
                  </Border>
                </Grid>
              </Grid>
            </Grid>
          </Border>
        </Grid>
      </Grid>
    </Border>
  </Grid>
</Window>
